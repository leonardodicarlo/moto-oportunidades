# ============================================================
# Moto Oportunidades — Configuración de entorno
# Copiá este archivo como .env y completá los valores
# ============================================================

# ----- Credenciales MercadoLibre (opcionales) ---------------
# Sin credenciales la app funciona con la API pública (límite de rate menor).
# Para obtener credenciales: https://developers.mercadolibre.com.ar/
ML_APP_ID=
ML_ACCESS_TOKEN=

# ----- Análisis de precios ----------------------------------
# % por debajo de la mediana para considerar "bajo mercado" (ej: 0.20 = 20%)
PRICE_BELOW_THRESHOLD=0.20

# Precio mínimo en ARS para filtrar accesorios/anticipos irrisorios
MIN_PRICE_ARS=800000

# Máximo de resultados a traer por marca (máx recomendado: 400)
MAX_RESULTS_PER_BRAND=200

# ----- API --------------------------------------------------
# Delay en segundos entre llamadas a la API (para no superar rate limit)
RATE_LIMIT_DELAY=0.4

# ----- Output -----------------------------------------------
# Exportar resultados a CSV (true/false)
EXPORT_CSV=true
CSV_OUTPUT_FILE=resultados.csv
